<?xml version="1.0" encoding="UTF-8"?>
<!--
Combined 4-Experiment Atmospheric Neutrino CPT Analysis with Xsec Systematics

Experiments: ORCA (1yr), IC DeepCore (7.74yr), ICUpgrade (10yr), SuperK 2023 (1yr)

Nuisance parameters: 29 total
  - 7 flux (shared across all experiments)
  - 10 xsec (shared; Mode-dependent params are no-ops for ORCA/SK where Mode=0)
  - 7 ORCA detector systematics
  - 5 IC DeepCore hypersurface detector systematics

Note: IC DeepCore requires explicit load_hypersurfaces() call in the row worker.
      SuperK requires PYNU env var set for FLUKA flux initialization.
-->
<Analysis>

<!-- ======================================================================= -->
<!-- Atmospheric Flux Systematics (shared across all experiments) -->
<!-- ======================================================================= -->
<NeutrinoSource name="Atmospheric">
    <status> 1 </status>

    <nuisance name='normalization_below1GeV'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='normalization_above1GeV'>
        <status> 1 </status>
        <sigma> 0.15 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='tilt'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='nunubar_ratio'>
        <status> 1 </status>
        <sigma> 0.02 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='flavor_ratio'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_up'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_down'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoSource>

