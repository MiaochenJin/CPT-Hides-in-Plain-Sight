<?xml version="1.0" encoding="UTF-8"?>
<!--
IceCube Upgrade Atmospheric Neutrino CPT Analysis Configuration
Based on IceCubeUpgradeNeutrinoMCDataRelease-2 public MC

Uses 3-Osc-CPT oscillations (separate Dm231 and Dm231_bar) with Barlow-Beeston likelihood.
Exposure: 10 years (long-term ICUp projection)
No muon background, no detector systematics (not in data release).
-->
<Analysis>

<!-- ======================================================================= -->
<!-- Atmospheric Flux Systematics -->
<!-- ======================================================================= -->
<NeutrinoSource name="Atmospheric">
    <status> 1 </status>

    <nuisance name='normalization_below1GeV'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='normalization_above1GeV'>
        <status> 1 </status>
        <sigma> 0.15 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='tilt'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='nunubar_ratio'>
        <status> 1 </status>
        <sigma> 0.02 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='flavor_ratio'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_up'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_down'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoSource>

<!-- ======================================================================= -->
<!-- Cross-Section Systematics (Water/Ice target) -->
<!-- ======================================================================= -->
<NeutrinoTarget name="Water">
    <status> 1 </status>

    <nuisance name='XSecNuTau'>
        <status> 0 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCoverCC'>
        <status> 0 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoTarget>

<!-- ======================================================================= -->
<!-- IceCube Upgrade Detector Configuration -->
<!-- ======================================================================= -->
<NeutrinoExperiment name="ICUpgrade">
    <status> 1 </status>
    <target name="Water"> </target>

    <source name='Atmospheric'>
        <status> 1 </status>
        <!-- MC file: ICUp data release neutrino MC -->
        <MCFiles name='${DATA_DIR}/IceCubeUpgradeNeutrinoMCDataRelease-2/events/neutrino_mc.csv'>
            <status> 1 </status>
        </MCFiles>
        <!-- Exposure: 10 years (long-term ICUp projection) -->
        <exposure> 10.0 </exposure>
        <!-- MCexposure: 1.0 (weights already normalized per-unit) -->
        <MCexposure> 1.0 </MCexposure>
        <!-- No data file (MC-only release) -->
        <DataFiles name='none'>
            <status> 0 </status>
        </DataFiles>
    </source>

    <!-- No detector nuisance params (no ice gradient data in release) -->

</NeutrinoExperiment>

<!-- ======================================================================= -->
<!-- Physics Scenario: 3-flavor CPT Oscillations (separate nu/nubar Dm231) -->
<!-- ======================================================================= -->
<NeutrinoOscillations name="3-Osc-CPT">
    <status> 1 </status>
    <flavors> 3 </flavors>

    <!-- Fixed parameters -->
    <fixed name='Sin2Theta12'>
        <status> 1 </status>
        <value> 0.303 </value>
    </fixed>

    <fixed name='Sin2Theta13'>
        <status> 1 </status>
        <value> 0.022 </value>
    </fixed>

    <fixed name='Sin2Theta23'>
        <status> 1 </status>
        <value> 0.572 </value>
    </fixed>

    <fixed name='Dm221'>
        <status> 1 </status>
        <value> 7.41e-5 </value>
    </fixed>

    <fixed name='dCP'>
        <status> 1 </status>
        <value> 1.36 </value>
    </fixed>

    <!-- Dm231 scan range -->
    <physics name='Dm231'>
        <points> 2 </points>
        <min> 2.3e-3 </min>
        <max> 2.7e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <physics name='Ordering'>
        <points> 1 </points>
        <min> normal </min>
        <max> normal </max>
        <true> normal </true>
    </physics>
</NeutrinoOscillations>

</Analysis>
