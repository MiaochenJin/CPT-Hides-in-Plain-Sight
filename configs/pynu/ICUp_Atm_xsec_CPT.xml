<?xml version="1.0" encoding="UTF-8"?>
<!--
IceCube Upgrade Atmospheric Neutrino Analysis - with Cross-Section Systematics (CPT)

Based on ICUp_Atm_xsec.xml. Uses 3-Osc-CPT oscillation model for CPT scans.

Xsec params enabled:
  CC/NC-level: XSecNuTau, NCoverCC, AxialMass, NCHad
  Mode-dependent: DIS, CCQE, CCQENuBarNu, CCQEMuE, CC1PiProduction, CohPiProduction
-->
<Analysis>

<!-- Atmospheric Flux Systematics -->
<NeutrinoSource name="Atmospheric">
    <status> 1 </status>

    <nuisance name='normalization_below1GeV'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='normalization_above1GeV'>
        <status> 1 </status>
        <sigma> 0.15 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='tilt'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='nunubar_ratio'>
        <status> 1 </status>
        <sigma> 0.02 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='flavor_ratio'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_up'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_down'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoSource>

<!-- Cross-Section Systematics — ALL ENABLED -->
<NeutrinoTarget name="Water">
    <status> 1 </status>

    <!-- CC/NC-level params (no Mode needed) -->
    <nuisance name='XSecNuTau'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCoverCC'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='AxialMass'>
        <status> 1 </status>
        <sigma> 0.03 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCHad'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <!-- Mode-dependent params (need interaction_type) -->
    <nuisance name='DIS'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='CCQE'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='CCQENuBarNu'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='CCQEMuE'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='CC1PiProduction'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='CohPiProduction'>
        <status> 1 </status>
        <sigma> 0.3 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoTarget>

<!-- IceCube Upgrade Detector Configuration -->
<NeutrinoExperiment name="ICUpgrade">
    <status> 1 </status>
    <target name="Water"> </target>

    <source name='Atmospheric'>
        <status> 1 </status>
        <MCFiles name='${DATA_DIR}/IceCubeUpgradeNeutrinoMCDataRelease-2/events/neutrino_mc.csv'>
            <status> 1 </status>
        </MCFiles>
        <exposure> 10.0 </exposure>
        <MCexposure> 1.0 </MCexposure>
        <DataFiles name='none'>
            <status> 0 </status>
        </DataFiles>
    </source>
</NeutrinoExperiment>

<!-- Physics: 3-flavor CPT Oscillations -->
<NeutrinoOscillations name="3-Osc-CPT">
    <status> 1 </status>
    <flavors> 3 </flavors>

    <fixed name='Sin2Theta12'>
        <status> 1 </status>
        <value> 0.303 </value>
    </fixed>

    <fixed name='Sin2Theta13'>
        <status> 1 </status>
        <value> 0.022 </value>
    </fixed>

    <fixed name='Sin2Theta23'>
        <status> 1 </status>
        <value> 0.572 </value>
    </fixed>

    <fixed name='Dm221'>
        <status> 1 </status>
        <value> 7.41e-5 </value>
    </fixed>

    <fixed name='dCP'>
        <status> 1 </status>
        <value> 1.36 </value>
    </fixed>

    <physics name='Dm231'>
        <points> 2 </points>
        <min> 2.3e-3 </min>
        <max> 2.7e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <physics name='Ordering'>
        <points> 1 </points>
        <min> normal </min>
        <max> normal </max>
        <true> normal </true>
    </physics>
</NeutrinoOscillations>

</Analysis>
