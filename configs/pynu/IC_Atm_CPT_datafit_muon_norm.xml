<?xml version="1.0" encoding="UTF-8"?>
<!--
IceCube DeepCore 9-year CPT Invariance Analysis Configuration
DATA FITTING MODE with muon_norm enabled

Same as IC_Atm_CPT_datafit.xml but with muon_norm nuisance status=1.
-->
<Analysis>

<!-- ======================================================================= -->
<!-- Atmospheric Flux Systematics -->
<!-- ======================================================================= -->
<NeutrinoSource name="Atmospheric">
    <status> 1 </status>

    <nuisance name='normalization_below1GeV'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='normalization_above1GeV'>
        <status> 1 </status>
        <sigma> 0.15 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='tilt'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='nunubar_ratio'>
        <status> 1 </status>
        <sigma> 0.02 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='flavor_ratio'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_up'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_down'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoSource>

<!-- ======================================================================= -->
<!-- Cross-Section Systematics (Water/Ice target) -->
<!-- ======================================================================= -->
<NeutrinoTarget name="Water">
    <status> 1 </status>

    <nuisance name='XSecNuTau'>
        <status> 0 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCoverCC'>
        <status> 0 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoTarget>

<!-- ======================================================================= -->
<!-- IceCube DeepCore Detector Configuration -->
<!-- ======================================================================= -->
<NeutrinoExperiment name="IceCube-DeepCore">
    <status> 1 </status>
    <target name="Water"> </target>

    <source name='Atmospheric'>
        <status> 1 </status>
        <MCFiles name='${DATA_DIR}/Pynu/data/IceCube/IC_MC.parquet'>
            <status> 1 </status>
        </MCFiles>
        <exposure> 7.74 </exposure>
        <MCexposure> 100.0 </MCexposure>
        <DataFiles name='${DATA_DIR}/Pynu/data/IceCube/IC_data.parquet'>
            <status> 1 </status>
        </DataFiles>
    </source>

    <!-- IceCube detector systematics (hypersurface parameters) -->
    <nuisance name='dom_eff'>
        <status> 1 </status>
        <sigma> 0.10 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='hole_ice_p0'>
        <status> 1 </status>
        <sigma> 0.10 </sigma>
        <nominal> 0.10 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='hole_ice_p1'>
        <status> 1 </status>
        <sigma> 0.10 </sigma>
        <nominal> -0.05 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='bulk_ice_abs'>
        <status> 1 </status>
        <sigma> 0.10 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='bulk_ice_scatter'>
        <status> 1 </status>
        <sigma> 0.10 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='muon_norm'>
        <status> 1 </status>
        <sigma> 0.5 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoExperiment>

<!-- ======================================================================= -->
<!-- Physics Scenario: CPT Oscillations -->
<!-- ======================================================================= -->
<NeutrinoOscillations name="3-Osc-CPT">
    <status> 1 </status>
    <flavors> 3 </flavors>

    <fixed name='Sin2Theta12'>
        <status> 1 </status>
        <value> 0.303 </value>
    </fixed>

    <fixed name='Sin2Theta13'>
        <status> 1 </status>
        <value> 0.022 </value>
    </fixed>

    <fixed name='Sin2Theta23'>
        <status> 1 </status>
        <value> 0.572 </value>
    </fixed>

    <fixed name='Dm221'>
        <status> 1 </status>
        <value> 7.41e-5 </value>
    </fixed>

    <fixed name='dCP'>
        <status> 1 </status>
        <value> 1.36 </value>
    </fixed>

    <!-- Dm231 scan range (overridden by row worker) -->
    <physics name='Dm231'>
        <points> 2 </points>
        <min> 2.3e-3 </min>
        <max> 2.7e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <physics name='Ordering'>
        <points> 1 </points>
        <min> normal </min>
        <max> normal </max>
        <true> normal </true>
    </physics>
</NeutrinoOscillations>

</Analysis>
