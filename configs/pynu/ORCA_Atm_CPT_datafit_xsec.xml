<?xml version="1.0" encoding="UTF-8"?>
<!--
ORCA Atmospheric Neutrino CPT Analysis Configuration
DATA FITTING MODE — Uses real ORCA data as observation

Uses real AtmOsc oscillations with Barlow-Beeston likelihood.

The Dm231 and Dm231_bar parameters are set externally by run_orca_cpt_datafit_row_worker.py
This config sets up the experiment, systematics, and fixed oscillation parameters.
-->
<Analysis>

<!-- ======================================================================= -->
<!-- Atmospheric Flux Systematics -->
<!-- ======================================================================= -->
<NeutrinoSource name="Atmospheric">
    <status> 1 </status>

    <nuisance name='normalization_below1GeV'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='normalization_above1GeV'>
        <status> 1 </status>
        <sigma> 0.15 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='tilt'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='nunubar_ratio'>
        <status> 1 </status>
        <sigma> 0.02 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='flavor_ratio'>
        <status> 1 </status>
        <sigma> 0.05 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_up'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='zenith_down'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 0.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoSource>

<!-- ======================================================================= -->
<!-- Cross-Section Systematics (4 CC/NC-level; ORCA std lacks interaction_type) -->
<!-- ======================================================================= -->
<NeutrinoTarget name="Water">
    <status> 1 </status>

    <nuisance name='XSecNuTau'>
        <status> 1 </status>
        <sigma> 0.25 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCoverCC'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='AxialMass'>
        <status> 1 </status>
        <sigma> 0.03 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='NCHad'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoTarget>

<!-- ======================================================================= -->
<!-- ORCA Detector Configuration -->
<!-- ======================================================================= -->
<NeutrinoExperiment name="ORCA">
    <status> 1 </status>
    <target name="Water"> </target>

    <source name='Atmospheric'>
        <status> 1 </status>
        <!-- Use ORCA MC file -->
        <MCFiles name='${DATA_DIR}/Pynu/data/ORCA/ORCA_MC_dataverse_with_muons.parquet'>
            <status> 1 </status>
        </MCFiles>
        <exposure> 1.0 </exposure>
        <MCexposure> 100.0 </MCexposure>
        <!-- Data fitting mode: use real data as observation -->
        <DataFiles name='${DATA_DIR}/Pynu/data/ORCA/ORCA_data_dataverse.parquet'>
            <status> 1 </status>
        </DataFiles>
    </source>

    <!-- ORCA-specific detector systematics -->
    <nuisance name='f_all'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='f_HPT'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='f_Shower'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='f_tauCC'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='f_NC'>
        <status> 1 </status>
        <sigma> 0.2 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='f_HE'>
        <status> 1 </status>
        <sigma> 0.5 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='E_shift'>
        <status> 1 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

    <nuisance name='muon_norm'>
        <status> 0 </status>
        <sigma> 0.5 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>
</NeutrinoExperiment>

<!-- ======================================================================= -->
<!-- Physics Scenario: CPT Oscillations -->
<!-- Dm231 and Dm231_bar are set externally by the CPT analysis script -->
<!-- ======================================================================= -->
<NeutrinoOscillations name="3-Osc-CPT">
    <status> 1 </status>
    <flavors> 3 </flavors>

    <!-- Fixed parameters -->
    <fixed name='Sin2Theta12'>
        <status> 1 </status>
        <value> 0.303 </value>
    </fixed>

    <fixed name='Sin2Theta13'>
        <status> 1 </status>
        <value> 0.022 </value>
    </fixed>

    <fixed name='Sin2Theta23'>
        <status> 1 </status>
        <value> 0.572 </value>
    </fixed>

    <fixed name='Dm221'>
        <status> 1 </status>
        <value> 7.41e-5 </value>
    </fixed>

    <fixed name='dCP'>
        <status> 1 </status>
        <value> 1.36 </value>
    </fixed>

    <!-- Dm231 grid - we need at least 2 points to be treated as physics -->
    <!-- The actual CPT scan in the row worker overrides these values -->
    <physics name='Dm231'>
        <points> 2 </points>
        <min> 2.3e-3 </min>
        <max> 2.7e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <physics name='Ordering'>
        <points> 1 </points>
        <min> normal </min>
        <max> normal </max>
        <true> normal </true>
    </physics>
</NeutrinoOscillations>

</Analysis>
