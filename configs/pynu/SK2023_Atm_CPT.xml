    <nuisance name='mge_nonubkg'>
        <status> 0 </status>
        <sigma> 0.1 </sigma>
        <nominal> 1.0 </nominal>
        <distribution> normal </distribution>
    </nuisance>

</NeutrinoExperiment>

<!-- ======================================================================= -->
<!-- Physics Scenario: CPT 3-flavor Oscillations -->
<!-- ======================================================================= -->
<NeutrinoOscillations name="3-Osc-CPT">
    <status> 1 </status>
    <flavors> 3 </flavors>

    <!-- Fixed parameters -->
    <fixed name='Sin2Theta12'>
        <status> 1 </status>
        <value> 0.303 </value>
    </fixed>

    <fixed name='Sin2Theta13'>
        <status> 1 </status>
        <value> 0.022 </value>
    </fixed>

    <fixed name='Sin2Theta23'>
        <status> 1 </status>
        <value> 0.572 </value>
    </fixed>

    <fixed name='Dm221'>
        <status> 1 </status>
        <value> 7.41e-5 </value>
    </fixed>

    <fixed name='dCP'>
        <status> 1 </status>
        <value> 1.36 </value>
    </fixed>

    <!-- Dm231 scan range (neutrinos) -->
    <physics name='Dm231'>
        <points> 2 </points>
        <min> 2.0e-3 </min>
        <max> 3.0e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <!-- Dm231_bar scan range (antineutrinos) -->
    <physics name='Dm231_bar'>
        <points> 2 </points>
        <min> 2.0e-3 </min>
        <max> 3.0e-3 </max>
        <true> 2.511e-3 </true>
    </physics>

    <physics name='Ordering'>
        <points> 1 </points>
        <min> normal </min>
        <max> normal </max>
        <true> normal </true>
    </physics>
</NeutrinoOscillations>

</Analysis>
