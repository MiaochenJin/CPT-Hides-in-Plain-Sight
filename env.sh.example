# Environment for the CPT neutrino analysis.
#
#   cp env.sh.example env.sh    # env.sh is gitignored
#   $EDITOR env.sh              # fill in the paths for your machine
#   source env.sh
#
# Nothing in this repo hardcodes an absolute path; every machine-specific
# location is set here.

# --- Pynu framework -----------------------------------------------------------
# Directory that CONTAINS the `pynu` package. Defaults to the bundled submodule;
# only override to use an existing checkout.
export PYNU_DIR="$(pwd)/external/Pynu"

# Pynu's Super-K flux initialization reads $PYNU. Leave as-is unless you know better.
export PYNU="${PYNU_DIR}/pynu"

# --- Data ---------------------------------------------------------------------
# Root directory holding the MC/data files referenced by the XML configs.
# The configs expand ${DATA_DIR}/... at run time. See docs/INSTALL.md for the
# expected sub-layout and where to obtain each file.
export DATA_DIR="/path/to/cpt-data"

# --- nuSQuIDS -----------------------------------------------------------------
# Cross-section / oscillation data tables shipped with nuSQuIDS.
export NUSQUIDS_DATA_PATH="/path/to/nuSQuIDS/share/nuSQuIDS"

# --- GLoBES (accelerator CP-CPT study only) -----------------------------------
# Install prefix containing lib/libglobes and bin/globes. Only needed for the
# DUNE GLoBES analysis.
export GLOBES_PREFIX="/path/to/globes"
export LD_LIBRARY_PATH="${GLOBES_PREFIX}/lib:${LD_LIBRARY_PATH}"

# --- Repo configs (rarely changed) --------------------------------------------
# Override only if you move the configs/ directory.
# export CONFIG_DIR="$(pwd)/configs"
